# Backend environment configuration. Copy to `.env` and fill in real values.
# `.env` is git-ignored. NEVER commit it.

# EmailJS configuration — used by the email service to send real SMTP emails
# during the bourse flow (2FA, code A, code B, etc.). Both keys are required
# because EmailJS Node SDK validates server-side requests against them.
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
